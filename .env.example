# DeepSeek API key (required for M1 examples and C10+ provider).
# Copy to .env and fill in your key:  cp .env.example .env
DEEPSEEK_API_KEY=

# Optional overrides (C10 defaults if unset):
# Base URL — do NOT include a trailing /v1 (the code appends it; both forms are tolerated):
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek-v4-pro
# Legacy (deprecated 2026-07-24): deepseek-chat, deepseek-reasoner
# Thinking mode (default disabled for MVP): enabled | disabled
# DEEPSEEK_THINKING=disabled
